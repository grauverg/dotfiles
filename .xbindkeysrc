###########################
# xbindkeys configuration #
###########################

#########################
# --// volume ctrl //-- #
#########################

# set volume by +5
"amixer set Master 5%+"
  m:0x0 + c:123
  XF86AudioRaiseVolume

# set volume by -5
"amixer set Master 5%-"
  m:0x0 + c:122
  XF86AudioLowerVolume

# toggle volume on/off
"amixer set Master toggle"
  m:0x0 + c:121
  XF86AudioMute

#############################
# --// brightness ctrl //-- #
#############################

# increase screen brightness by 10
"xbacklight -inc 10"
  m:0x0 + c:233
  XF86MonBrightnessUp

# decrease screen brightness by 10
"xbacklight -dec 10"
  m:0x0 + c:232
  XF86MonBrightnessDown

###########################
# --// jbl-spec ctrl //-- #
###########################

"playerctl play-pause"
  m:0x0 + c:209
  XF86AudioPause

"playerctl play-pause"
  m:0x0 + c:208
  XF86AudioPlay

"playerctl next"
  m:0x0 + c:171
  XF86AudioNext

##################################
# End of xbindkeys configuration #
##################################
